---
import Layout from "../layouts/Layout.astro";

// don't remove for now
const pastProjects = [
  {
    name: "Cachet",
    description:
      "A *really fast* proxy to quickly grab Hack Club Slack profile pictures without Slack API hassle.",
    link: "https://cachet.dunkirk.sh",
  },
  {
    name: "Battleships API",
    description: "Play an entire game of Battleships over an API.",
    link: "https://github.com/pbhak/battleships-api",
  },
  {
    name: "ytdlp Web API",
    description: "Download Youtube videos with one call.",
    link: "https://github.com/duykhanh09103/ytdlp-web-api",
  },
];
---

<Layout>
  <main class="homepage min-h-screen w-full relative overflow-hidden">
    <h1 class="hero-title select-none">RASPAPI</h1>

    <img
      src="/rpizero-topdown.png"
      alt="Raspberry Pi Zero 2W — top-down view"
      class="pi-image pointer-events-none select-none"
      draggable="false"
    />

    <div class="mobile-btns">
      <a href="/guides" class="side-btn side-btn--left"> GUIDES </a>

      <button type="button" disabled class="side-btn side-btn--right">
        SUBMIT
      </button>
    </div>

    <p class="tagline">
      BUILD AN API. GET A RASPBERRY PI ZERO 2W TO HOST IT ON.
    </p>
  </main>
</Layout>

<style>
  .homepage {
    background-image: url("https://www.transparenttextures.com/patterns/axiom-pattern.png");
    background-repeat: repeat;
  }

  .hero-title {
    position: absolute;
    top: 8%;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: clamp(4.5rem, 10vw, 12rem);
    letter-spacing: 0.18em;
    color: #fff;
    z-index: 1;
    text-align: center;
    line-height: 1;
    white-space: nowrap;
  }

  .tagline {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    margin: 0;
    font-family: "Syne", sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.45em;
    color: #525252;
    white-space: nowrap;
    text-align: center;
  }

  .pi-image {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: min(90vw, 950px);
    height: auto;
    filter: drop-shadow(0 12px 60px rgba(0, 0, 0, 0.6));
  }

  .side-btn {
    position: fixed;
    z-index: 40;
    top: 50%;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-family: "Syne", sans-serif;
    font-weight: 800;
    font-size: 0.875rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    padding: 1.5rem 0.75rem;
    border: 2px solid #404040;
    background: rgba(10, 10, 10, 0.9);
    color: #e5e5e5;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s,
      background 0.2s;
    cursor: pointer;
  }

  .side-btn:hover {
    border-color: #c41e3a;
    color: #fff;
    background: rgba(196, 30, 58, 0.1);
  }

  .side-btn--left {
    left: 0;
  }

  .side-btn--right {
    right: 0;
    transform: none;
    cursor: not-allowed;
    opacity: 0.5;
  }

  .side-btn--right:hover {
    color: #e5e5e5;
    border-color: #404040;
    background: rgba(10, 10, 10, 0.9);
  }

  .mobile-btns {
    display: contents;
  }

  /* mobile nonsense */
  @media (max-width: 768px) {
    .homepage {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100dvh;
      padding: 0 1rem 4rem;
    }

    .hero-title {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      margin-top: 3rem;
      font-size: clamp(3rem, 12vw, 5rem);
    }

    .pi-image {
      position: relative;
      bottom: auto;
      left: auto;
      transform: none;
      width: 90vw;
      max-width: 500px;
      margin-top: 1.5rem;
    }

    .mobile-btns {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
      max-width: 500px;
      margin-top: 2rem;
      z-index: 40;
    }

    .side-btn {
      position: static;
      writing-mode: horizontal-tb;
      text-orientation: initial;
      transform: none;
      width: 100%;
      text-align: center;
      padding: 1rem;
      font-size: 0.8rem;
      letter-spacing: 0.4em;
    }

    .side-btn--right {
      transform: none;
    }

    .tagline {
      position: relative;
      bottom: auto;
      left: auto;
      transform: none;
      margin-top: 2rem;
      white-space: normal;
      font-size: 0.55rem;
      letter-spacing: 0.3em;
      padding: 0 0.5rem;
    }
  }
</style>
