---
// biome-ignore lint/correctness/noUnusedImports: shut up
import Layout from "../layouts/Layout.astro";
import { getPendingSubmissions } from "../lib/airtable";
import {
  createProject as createFraudProject,
  listProjects,
} from "../lib/fraud";
import { getSession } from "../lib/session";

const session = await getSession(Astro.cookies, import.meta.env.SESSION_SECRET);
if (!session) return Astro.redirect("/auth/login");

const adminIds = (import.meta.env.ADMIN_IDS ?? "")
  .split(",")
  .map((s: string) => s.trim())
  .filter(Boolean);
if (!adminIds.includes(session.slack_id)) return Astro.redirect("/me");

const [submissions, fraudData] = await Promise.all([
  getPendingSubmissions(),
  listProjects().catch(() => ({ projects: [] })),
]);

const fraudByOrgId = new Map(
  (fraudData.projects ?? []).map((p) => [p.organizerPlatformId, p]),
);

const missingInFraud = submissions.filter((sub) => !fraudByOrgId.has(sub.id));
if (missingInFraud.length > 0) {
  await Promise.allSettled(
    missingInFraud.map((sub) =>
      createFraudProject(
        sub.project_name,
        sub.repo_url ?? "",
        sub.project_url ?? "",
        sub.user_slack_id,
        sub.hackatime_project ? [sub.hackatime_project] : [],
        sub.id,
      ).catch((e) => console.error("[review] fraud createProject failed:", e)),
    ),
  );
  const updatedFraud = await listProjects().catch(() => ({ projects: [] }));
  for (const p of updatedFraud.projects ?? []) {
    fraudByOrgId.set(p.organizerPlatformId, p);
  }
}

const approvedSubmissions = submissions;
---

<Layout>
  <main class="page">
    <header class="topbar">
      <span class="label">REVIEW QUEUE</span>
      <div class="actions">
        <span class="count">{approvedSubmissions.length} pending</span>
        <button id="btn-export" class="btn-export">export csv</button>
        <a href="/me" class="back">dashboard</a>
      </div>
    </header>

    <section class="content">
      {
        approvedSubmissions.length === 0 ? (
          <p class="empty">No submissions to review</p>
        ) : (
          <div class="submissions-list">
            {approvedSubmissions.map((sub) => {
              const fraud = fraudByOrgId.get(sub.id);
              const trustScore = fraud?.review?.trustScore ?? null;
              const fraudStatus =
                fraud?.outcome?.status ?? (fraud ? "pending" : "not submitted");
              return (
                <div
                  class="submission-card"
                  data-id={sub.id}
                  data-project-id={sub.project_id}
                  data-hours={sub.hours_at_submission}
                  data-user-slack-id={sub.user_slack_id}
                  data-project-name={sub.project_name}
                  data-project-url={sub.project_url ?? ""}
                  data-repo-url={sub.repo_url ?? ""}
                >
                  <div class="submission-header">
                    <div class="submission-info">
                      <h2 class="project-name">{sub.project_name}</h2>
                      <p class="submitter" data-slack-id={sub.user_slack_id}>
                        by{" "}
                        <span class="submitter-name">{sub.user_slack_id}</span>
                        <span class="submitter-id">({sub.user_slack_id})</span>
                      </p>
                    </div>
                    <div class="submission-meta">
                      <span class={`fraud-status fraud-status--${fraudStatus}`}>
                        {fraudStatus}
                      </span>
                      {trustScore !== null && (
                        <span
                          class={`fraud-score fraud-score--${trustScore >= 7 ? "high" : trustScore >= 4 ? "mid" : "low"}`}
                        >
                          trust {trustScore}/10
                        </span>
                      )}
                      <span class="hours">
                        {sub.hours_at_submission.toFixed(2)}h
                      </span>
                      <span class="date">
                        {new Date(sub.created_at).toLocaleDateString()}
                      </span>
                    </div>
                  </div>

                  <div class="submission-details">
                    {sub.project_description && (
                      <p class="description">{sub.project_description}</p>
                    )}
                    <div class="links">
                      {sub.project_url && (
                        <a
                          href={sub.project_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link"
                        >
                          project
                        </a>
                      )}
                      {sub.repo_url && (
                        <a
                          href={sub.repo_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link"
                        >
                          repo
                        </a>
                      )}
                    </div>
                  </div>

                  <button class="btn-review" data-id={sub.id}>
                    Review
                  </button>
                </div>
              );
            })}
          </div>
        )
      }
    </section>

    <!-- Review Modal -->
    <div id="review-modal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title">Review Submission</h2>
          <button class="modal-close">&times;</button>
        </div>

        <div class="modal-body">
          <div class="review-project-info">
            <h3 id="review-project-name"></h3>
            <p id="review-submitter"></p>
            <p id="review-submitter-id" class="review-slack-id"></p>
            <p id="review-hours"></p>
            <div class="review-links">
              <a
                id="review-project-link"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="link hidden">project</a
              >
              <a
                id="review-repo-link"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                class="link hidden">repo</a
              >
            </div>
          </div>

          <div class="buff-section">
            <h4>Buff Checklist</h4>
            <p class="buff-hint">
              M starts at 1.0. Flat bonuses cap at 1.5 before multipliers.
            </p>

            <div class="buff-group">
              <span class="buff-group-label">Flat Bonuses (additive)</span>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="auth"
                  data-value="0.15"
                />
                <span>Authorization (JWT, user tokens, API keys): +0.15</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="persistence"
                  data-value="0.10"
                />
                <span>Persistence (database, file storage): +0.10</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="external_api"
                  data-value="0.10"
                />
                <span>Integrates with external API (non-trivial): +0.10</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="rate_limiting"
                  data-value="0.10"
                />
                <span>Rate limiting / abuse prevention: +0.10</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="pagination"
                  data-value="0.05"
                />
                <span>Pagination: +0.05</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="buff"
                  value="error_handling"
                  data-value="0.05"
                />
                <span>Proper error handling & input validation: +0.05</span>
              </label>
              <div class="buff-item endpoints-item">
                <label>
                  <span>Additional endpoints (max 4): +0.03 each</span>
                </label>
                <div class="endpoints-counter">
                  <button type="button" class="endpoint-btn" id="endpoints-dec"
                    >-</button
                  >
                  <span id="endpoints-count">0</span>
                  <button type="button" class="endpoint-btn" id="endpoints-inc"
                    >+</button
                  >
                </div>
              </div>
            </div>

            <div class="buff-group">
              <span class="buff-group-label"
                >Multipliers (applied after flat cap)</span
              >
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="multiplier"
                  value="cool_project"
                  data-value="1.3"
                />
                <span>Cool project: x1.3</span>
              </label>
              <label class="buff-item">
                <input
                  type="checkbox"
                  name="multiplier"
                  value="exceptional_quality"
                  data-value="1.2"
                />
                <span>Exceptional code quality / architecture: x1.2</span>
              </label>
            </div>

            <div class="multiplier-display">
              <div class="multiplier-breakdown" id="multiplier-breakdown">
                <span>Base: 1.0</span>
              </div>
              <div class="multiplier-result">
                <span>Final M:</span>
                <span id="final-multiplier" class="multiplier-value">1.00</span>
              </div>
              <div class="payout-preview">
                <span>Payout:</span>
                <span id="payout-preview" class="payout-value">0</span>
                <span class="payout-unit">raspberries</span>
              </div>
            </div>
          </div>

          <div class="notes-section">
            <label for="reviewer-notes">Reviewer Notes</label>
            <textarea
              id="reviewer-notes"
              rows="3"
              placeholder="Optional notes about this submission..."></textarea>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn-reject" id="btn-reject">Reject</button>
          <button class="btn-approve" id="btn-approve">Approve</button>
        </div>
      </div>
    </div>
  </main>

  <style>
