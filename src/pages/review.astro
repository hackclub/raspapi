      cursor: pointer;
      border: none;
    }

    .btn-reject {
      background: #1a1a1a;
      color: #c41e3a;
      border: 1px solid #c41e3a;
    }

    .btn-reject:hover {
      background: #c41e3a;
      color: #f5f5f5;
    }

    .btn-approve {
      background: #22c55e;
      color: #0a0a0a;
    }

    .btn-approve:hover {
      background: #16a34a;
    }

    .btn-reject:disabled,
    .btn-approve:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .hidden {
      display: none !important;
    }
  </style>

  <script>
    document.querySelectorAll<HTMLElement>(".submitter").forEach(async (el) => {
      const slackId = el.dataset.slackId;
      if (!slackId) return;
      try {
        const res = await fetch(`https://cachet.dunkirk.sh/users/${slackId}`);
        if (!res.ok) return;
        const data = await res.json();
        const nameEl = el.querySelector(".submitter-name");
        if (nameEl && data.displayName) {
          nameEl.textContent = data.displayName;
        }
      } catch {}
    });

    const modal = document.getElementById("review-modal")!;
    const backdrop = modal.querySelector(".modal-backdrop")!;
    const closeBtn = modal.querySelector(".modal-close")!;
    const approveBtn = document.getElementById(
      "btn-approve",
    ) as HTMLButtonElement;
    const rejectBtn = document.getElementById(
      "btn-reject",
    ) as HTMLButtonElement;
    const notesInput = document.getElementById(
      "reviewer-notes",
    ) as HTMLTextAreaElement;

    let currentSubmissionId: string | null = null;
    let currentHours = 0;
    let endpointsCount = 0;

    function closeModal() {
      modal.classList.add("hidden");
      currentSubmissionId = null;
      resetBuffs();
    }

    backdrop.addEventListener("click", closeModal);
    closeBtn.addEventListener("click", closeModal);

    document
      .querySelectorAll<HTMLButtonElement>(".btn-review")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const card = btn.closest(".submission-card") as HTMLElement;
          if (!card) return;

          currentSubmissionId = card.dataset.id!;
          currentHours = parseFloat(card.dataset.hours || "0");

          const projectName = card.dataset.projectName || "";
          const projectUrl = card.dataset.projectUrl || "";
          const repoUrl = card.dataset.repoUrl || "";
          const userSlackId = card.dataset.userSlackId || "";

          document.getElementById("review-project-name")!.textContent =
            projectName;
          document.getElementById("review-submitter")!.textContent =
            `Submitter: ${userSlackId}`;
          document.getElementById("review-submitter-id")!.textContent =
            `ID: ${userSlackId}`;
          document.getElementById("review-hours")!.textContent =
            `Hours: ${currentHours.toFixed(2)}h`;

          const projectLink = document.getElementById(
            "review-project-link",
          ) as HTMLAnchorElement;
          const repoLink = document.getElementById(
            "review-repo-link",
          ) as HTMLAnchorElement;

          if (projectUrl) {
            projectLink.href = projectUrl;
            projectLink.classList.remove("hidden");
          } else {
            projectLink.classList.add("hidden");
          }

          if (repoUrl) {
            repoLink.href = repoUrl;
            repoLink.classList.remove("hidden");
          } else {
            repoLink.classList.add("hidden");
          }

          fetch(`https://cachet.dunkirk.sh/users/${userSlackId}`)
            .then((r) => (r.ok ? r.json() : null))
            .then((d) => {
              if (d?.displayName) {
                document.getElementById("review-submitter")!.textContent =
                  `Submitter: ${d.displayName}`;
              }
            })
            .catch(() => {});

          resetBuffs();
          modal.classList.remove("hidden");
        });
      });

    function resetBuffs() {
      document
        .querySelectorAll<HTMLInputElement>('input[name="buff"]')
        .forEach((cb) => {
          cb.checked = false;
        });
      document
        .querySelectorAll<HTMLInputElement>('input[name="multiplier"]')
        .forEach((cb) => {
          cb.checked = false;
        });
      endpointsCount = 0;
      document.getElementById("endpoints-count")!.textContent = "0";
      notesInput.value = "";
      updateMultiplier();
    }

    function updateMultiplier() {
      let flatSum = 0;
      const breakdown: string[] = ["Base: 1.0"];

      document
        .querySelectorAll<HTMLInputElement>('input[name="buff"]:checked')
        .forEach((cb) => {
          const val = parseFloat(cb.dataset.value || "0");
          flatSum += val;
          const label =
            cb.parentElement
              ?.querySelector("span")
              ?.textContent?.split(":")[0] || "";
          breakdown.push(`${label}: +${val.toFixed(2)}`);
        });

      if (endpointsCount > 0) {
        const endpointsBonus = endpointsCount * 0.03;
        flatSum += endpointsBonus;
        breakdown.push(
          `Additional endpoints (${endpointsCount}): +${endpointsBonus.toFixed(2)}`,
        );
      }

      const flatM = Math.min(1.0 + flatSum, 1.5);
      if (flatSum > 0.5) {
        breakdown.push(`(capped at 1.5)`);
      }

      let finalM = flatM;
      const multipliers: string[] = [];

      document
        .querySelectorAll<HTMLInputElement>('input[name="multiplier"]:checked')
        .forEach((cb) => {
          const val = parseFloat(cb.dataset.value || "1");
          finalM *= val;
          const label =
            cb.parentElement
              ?.querySelector("span")
              ?.textContent?.split(":")[0] || "";
          multipliers.push(`${label}: x${val.toFixed(1)}`);
        });

      if (multipliers.length > 0) {
        breakdown.push(...multipliers);
      }

      document.getElementById("multiplier-breakdown")!.innerHTML = breakdown
        .map((line) => `<span>${line}</span>`)
        .join("<br>");

      document.getElementById("final-multiplier")!.textContent =
        finalM.toFixed(2);

      const payout = Math.round(currentHours * 4 * finalM);
      document.getElementById("payout-preview")!.textContent =
        payout.toString();
    }

    document
      .querySelectorAll<HTMLInputElement>(
        'input[name="buff"], input[name="multiplier"]',
      )
      .forEach((cb) => {
        cb.addEventListener("change", updateMultiplier);
      });

    document.getElementById("endpoints-dec")!.addEventListener("click", () => {
      if (endpointsCount > 0) {
        endpointsCount--;
        document.getElementById("endpoints-count")!.textContent =
          endpointsCount.toString();
        updateMultiplier();
      }
    });

    document.getElementById("endpoints-inc")!.addEventListener("click", () => {
      if (endpointsCount < 4) {
        endpointsCount++;
        document.getElementById("endpoints-count")!.textContent =
          endpointsCount.toString();
        updateMultiplier();
      }
    });

    async function submitReview(action: "approved" | "rejected") {
      if (!currentSubmissionId) return;

      approveBtn.disabled = true;
      rejectBtn.disabled = true;

      let flatSum = 0;
      const buffs: string[] = [];

      document
        .querySelectorAll<HTMLInputElement>('input[name="buff"]:checked')
        .forEach((cb) => {
          flatSum += parseFloat(cb.dataset.value || "0");
          buffs.push(cb.value);
        });

      if (endpointsCount > 0) {
        flatSum += endpointsCount * 0.03;
        buffs.push(`endpoints:${endpointsCount}`);
      }

      const flatM = Math.min(1.0 + flatSum, 1.5);
      let finalM = flatM;

      document
        .querySelectorAll<HTMLInputElement>('input[name="multiplier"]:checked')
        .forEach((cb) => {
          finalM *= parseFloat(cb.dataset.value || "1");
          buffs.push(cb.value);
        });

      try {
        const res = await fetch(`/api/review/${currentSubmissionId}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            action,
            multiplier: finalM,
            notes: notesInput.value.trim(),
            buffs,
          }),
        });

        const data = await res.json();
        if (!res.ok) {
          alert(data.error || "Failed to submit review");
          approveBtn.disabled = false;
          rejectBtn.disabled = false;
          return;
        }

        const card = document.querySelector(
          `.submission-card[data-id="${currentSubmissionId}"]`,
        );
        card?.remove();

        const countEl = document.querySelector(".count");
        if (countEl) {
          const remaining =
            document.querySelectorAll(".submission-card").length;
          countEl.textContent = `${remaining} pending`;
        }

        if (document.querySelectorAll(".submission-card").length === 0) {
          const content = document.querySelector(".content");
          if (content) {
            content.innerHTML = '<p class="empty">No submissions to review</p>';
          }
        }

        closeModal();
      } catch {
        alert("Network error");
        approveBtn.disabled = false;
        rejectBtn.disabled = false;
      }
    }

    document.getElementById("btn-export")!.addEventListener("click", () => {
      const cards = document.querySelectorAll<HTMLElement>(".submission-card");
      const rows: string[][] = [["name", "code_link", "demo_link", "slack_id"]];
      cards.forEach((card) => {
        rows.push([
          card.dataset.projectName || "",
          card.dataset.repoUrl || "",
          card.dataset.projectUrl || "",
          card.dataset.userSlackId || "",
        ]);
      });
      const csv = rows
        .map((r) => r.map((v) => `"${v.replace(/"/g, '""')}"`).join(","))
        .join("\n");
      const blob = new Blob([csv], { type: "text/csv" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "review-queue.csv";
      a.click();
      URL.revokeObjectURL(url);
    });

    approveBtn.addEventListener("click", () => submitReview("approved"));
    rejectBtn.addEventListener("click", () => {
      if (confirm("Are you sure you want to reject this submission?")) {
        submitReview("rejected");
      }
    });
  </script>
</Layout>
