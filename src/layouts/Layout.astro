---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href="/rpifavicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>RaspAPI</title>
  </head>
  <body class="bg-[#0a0a0a] text-[#f5f5f5] font-['Inter',sans-serif]">
    <a
      href="https://hackclub.com"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed top-0 left-0 z-50"
    >
      <img
        src="https://assets.hackclub.com/flag-orpheus-top.svg"
        alt="Hack Club"
        class="w-24 md:w-32"
      />
    </a>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
